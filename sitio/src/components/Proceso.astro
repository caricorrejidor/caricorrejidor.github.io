<!-- PROCESO -->
<section id="proceso" class="sec-alt">
  <div class="wrap">
    <div class="sec-head">
      <span class="kicker">Cómo trabajo</span>
      <h2 class="sec-title">Simple y sin vueltas</h2>
      <p class="sec-sub">Trabajo claro, con tiempos y costos definidos desde el principio. Sin sorpresas.</p>
    </div>
    <div class="proc-grid">
      <div class="proc-step reveal">
        <div class="proc-n">01</div>
        <div class="proc-t">Charlamos</div>
        <div class="proc-d">Entiendo tu problema y qué necesitás, sin tecnicismos.</div>
      </div>
      <div class="proc-step reveal">
        <div class="proc-n">02</div>
        <div class="proc-t">Propongo</div>
        <div class="proc-d">Te armo una solución concreta, con tiempos y costo claro.</div>
      </div>
      <div class="proc-step reveal">
        <div class="proc-n">03</div>
        <div class="proc-t">Construyo</div>
        <div class="proc-d">Desarrollo con código limpio y te muestro avances reales.</div>
      </div>
      <div class="proc-step reveal">
        <div class="proc-n">04</div>
        <div class="proc-t">Entrego</div>
        <div class="proc-d">Lo dejo funcionando y te acompaño con soporte.</div>
      </div>
    </div>
  </div>
</section>
