---
---
<!-- CONTACTO -->
<section id="contacto">
  <div class="wrap">
    <div class="contact-box reveal">
      <span class="kicker">Contacto</span>
      <h2 class="sec-title">¿Arrancamos tu proyecto?</h2>
      <p class="contact-lead">Consultame sin compromiso. Respondo en menos de 24 horas hábiles.</p>
      <form class="contact-form" id="contactForm">
        <input type="hidden" name="access_key" value="96a9ea10-d812-4c09-ad93-2129a6305893">
        <input type="hidden" name="subject" value="Nueva consulta desde el landing">
        <input type="hidden" name="from_name" value="Landing soluciones.ia">
        <!-- honeypot anti-spam: debe quedar vacío -->
        <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none !important">
        <div class="cf-row">
          <input type="text" name="name" placeholder="Tu nombre" required autocomplete="name" aria-label="Tu nombre">
          <input type="email" name="email" placeholder="Tu email" required autocomplete="email" aria-label="Tu email">
        </div>
        <textarea name="message" placeholder="Contame brevemente tu proyecto o consulta" required aria-label="Tu mensaje"></textarea>
        <button type="submit">Enviar mensaje</button>
        <p class="cf-status" id="cfStatus" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>
