---
// Landing migrada desde public/index.html a página Astro (fiel 1:1).
// El CSS va en src/styles/landing.css (importado abajo).
// El JS va en <script is:inline> para que Astro lo deje tal cual.
import '../styles/landing.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProofBand from '../components/ProofBand.astro';
import Servicios from '../components/Servicios.astro';
import Proceso from '../components/Proceso.astro';
import Testimonio from '../components/Testimonio.astro';
import SobreMi from '../components/SobreMi.astro';
import Stack from '../components/Stack.astro';
import Faq from '../components/Faq.astro';
import Contacto from '../components/Contacto.astro';
import WhatsappFloat from '../components/WhatsappFloat.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soluciones informáticas a medida & IA</title>

<!-- SEO -->
<meta name="description" content="Diseño web, software a medida, inteligencia artificial, automatización y asesoría tecnológica. Convierto tus ideas y procesos en sistemas que funcionan, con trato cercano y sin vueltas.">
<meta name="keywords" content="desarrollo de software, soluciones informáticas, diseño web, inteligencia artificial, asesoría tecnológica, automatización, APIs, .NET, React, Buenos Aires">
<link rel="canonical" href="https://caricorrejidor.github.io/">

<!-- Open Graph / redes sociales -->
<meta property="og:type" content="website">
<meta property="og:title" content="Soluciones informáticas a medida & IA">
<meta property="og:description" content="Diseño web, software a medida, IA y asesoría tecnológica. Convierto tus ideas en sistemas que funcionan.">
<meta property="og:url" content="https://caricorrejidor.github.io/">
<meta property="og:locale" content="es_AR">
<meta name="twitter:card" content="summary">
<meta name="theme-color" content="#684FA3">

<!-- Favicon (SVG inline, sin request extra) -->
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`}>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

</head>
<body>

<!-- NAV + menú (componente compartido) -->
<Header variant="home" />

<Hero />
<ProofBand />
<Servicios />
<Proceso />
<Testimonio />
<SobreMi />
<Stack />
<Faq />
<Contacto />

<!-- FOOTER (componente compartido) -->
<Footer variant="home" />

<WhatsappFloat />

<script is:inline>
  // (El JS del nav —hamburguesa, fondo al scrollear y scroll-spy— vive en Header.astro)

  // Reveal on scroll
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Count-up de métricas
  const statsBox = document.querySelector('.proof-stats');
  if (statsBox && !reduce) {
    const animateCount = (el) => {
      const target = parseInt(el.dataset.count, 10);
      const prefix = el.dataset.prefix || '';
      const dur = 1100, start = performance.now();
      const tick = (now) => {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = prefix + Math.round(target * eased);
        if (p < 1) requestAnimationFrame(tick); else el.textContent = prefix + target;
      };
      requestAnimationFrame(tick);
    };
    const co = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { animateCount(e.target); co.unobserve(e.target); } });
    }, { threshold: 0.6 });
    statsBox.querySelectorAll('.n[data-count]').forEach((n) => co.observe(n));
  }

  // FAQ acordeón
  document.querySelectorAll('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const open = item.classList.toggle('open');
      btn.setAttribute('aria-expanded', open);
    });
  });

  // Formulario de contacto (Web3Forms, envío AJAX sin recargar)
  const form = document.getElementById('contactForm');
  if (form) {
    const status = document.getElementById('cfStatus');
    const btn = form.querySelector('button[type="submit"]');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.className = 'cf-status';
      status.textContent = 'Enviando…';
      btn.disabled = true;
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const json = await res.json();
        if (json.success) {
          form.reset();
          status.className = 'cf-status ok';
          status.textContent = '¡Gracias! Te respondo a la brevedad.';
        } else {
          status.className = 'cf-status err';
          status.textContent = 'Hubo un problema. Probá de nuevo o escribime por WhatsApp.';
        }
      } catch (err) {
        status.className = 'cf-status err';
        status.textContent = 'No se pudo enviar. Revisá tu conexión o escribime por WhatsApp.';
      } finally {
        btn.disabled = false;
      }
    });
  }
</script>

</body>
</html>
