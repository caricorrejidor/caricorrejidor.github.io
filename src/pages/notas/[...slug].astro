---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d) =>
  d.toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={`${post.data.title} — Carina Correjidor`} description={post.data.description}>
  <article class="post">
    <a href="/notas" class="back">← Notas</a>
    <h1>{post.data.title}</h1>
    <p class="lead">{post.data.description}</p>
    <div class="byline">
      <div class="avatar avatar-sm"><img src="/avatar.svg" alt="Carina Correjidor" /></div>
      <div>
        <span class="byline-name">Carina Correjidor</span>
        <time>{fmt(post.data.date)}</time>
      </div>
    </div>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>
